APP_NAME=SHIELD Guard Service
APP_ENV=production
API_PREFIX=/v1
LOG_LEVEL=INFO

DATA_DIR=./service_data
DATABASE_PATH=./service_data/jobs.db
REDIS_URL=redis://localhost:6379/15

REQUIRE_API_KEY=false
API_KEY=change-me
API_KEY_HEADER=X-API-Key
REQUEST_ID_HEADER=X-Request-ID
ALLOWED_ORIGINS=*

MAX_UPLOAD_SIZE_BYTES=524288000
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

TASK_SOFT_TIME_LIMIT_SEC=900
TASK_TIME_LIMIT_SEC=1200
RESULT_TTL_SECONDS=604800

WEBHOOK_TIMEOUT_SECONDS=8
WEBHOOK_MAX_ATTEMPTS=2
WEBHOOK_USER_AGENT=shield-guard-service/1.0

GUARD_FRAME_COUNT=8
GUARD_ENABLE_WHISPER=true
GUARD_ENABLE_OCR=true
GUARD_REGION=auto
TEXT_MAX_CHARS=50000

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_API_BASE=https://api.groq.com/openai/v1

LLM_API_KEY=
LLM_MODEL=
LLM_API_BASE=

ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp,.bmp
ALLOWED_VIDEO_EXTENSIONS=.mp4,.mov,.avi,.mkv,.webm,.m4v
ALLOWED_AUDIO_EXTENSIONS=.mp3,.wav,.m4a,.aac,.ogg,.flac
